#!/bin/sh
USAGE="Usage: $(basename "$0") <source-dir> <destination-dir> <create|clean>"

create() {
	echo "Creating $DEST_DIR_PRETTY symlinks"
	for thing in "$SRC_DIR"/*; do
		base=$(basename "$thing")
		full_dest="$DEST_DIR/$base"
		if [ ! -e "$full_dest" ]; then
			ln -vs "$thing" "$DEST_DIR"
		else
			echo "EXISTS; SKIPPING: $full_dest"
		fi
	done
}

clean() {
	echo "Cleaning $DEST_DIR_PRETTY symlinks"
	for thing in "$SRC_DIR"/*; do
		base=$(basename "$thing")
		full_dest="$DEST_DIR/$base"
		if [ -h "$full_dest" ]; then
			rm -v "$full_dest"
		else
			if [ -e "$full_dest" ]; then
				echo "NON-LINK; SKIPPING: $full_dest"
			else
				echo "Doesn't exist; skipping: $full_dest"
			fi
		fi
	done
}

usage() {
	echo "$USAGE"
	if [ "$1" ]; then
		echo "$1"
	fi
	exit 42
}

if [ "$#" -ne 3 ]; then
	usage "Requires 3 arguments"
fi

if [ -d "$1" ]; then
	SRC_DIR=$(realpath "$1")
else
	usage "$1 is not a directory"
fi

if [ -d "$2" ]; then
	DEST_DIR=$(realpath "$2")
else
	usage "$2 is not a directory"
fi

if [ "$1" == "$2" ]; then
	usage "Source and destination directories must differ"
fi

DEST_DIR_PRETTY=$(basename "$DEST_DIR")

case "$3" in
	"create")
		create
		;;
	"clean")
		clean
		;;
	*)
		usage "Action \"$3\" is not valid"
esac

echo
